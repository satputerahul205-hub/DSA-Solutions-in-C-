#include<bits/stdc++.h>
using namespace std;
void maxsubarraySum(int *arr,int n){
    int maxsum=INT_MIN;
    for(int st=0;st<n;st++){                        // Time compexity is O(n^3)
        for(int end=st;end<n;end++){
            int currsum=0;
            for(int i=st;i<=end;i++){
                currsum+=arr[i];
            }
            maxsum=max(maxsum,currsum);
    }
    cout<<"maximum subarray sum is = "<<maxsum<<endl;;

}
void maxsubarraySumI(int *arr,int n){
    int maxsum=INT_MIN;
    for(int st=0;st<n;st++){
        int currsum=0;                                  // Time compexity is O(n^2)
        for(int end=st;end<n;end++){
            currsum+=arr[end];
        }
        maxsum=max(maxsum,currsum);
    }
     cout<<"maximum subarray sum is = "<<maxsum<<endl;;

}
void maxsubarraySumII(int *arr,int n){
    int currsum=0;                                 // This is Kadane's Algorithm
    int maxsum=INT_MIN;
    for(int i=0;i<n;i++){                                 // Time compexity is O(n)
        currsum+=arr[i];
        maxsum=max(maxsum,currsum);
    if(currsum < 0){
        currsum=0;
    }
    
    }
    cout<<"maximum subarray sum is = "<<maxsum<<endl;;

}
int main(){
    int arr[]={2,-3,6,-5,4,2};
  int n=sizeof(arr)/4;
  maxsubarraySum(arr,n);
  maxsubarraySumI(arr,n);
  maxsubarraySumII(arr,n);

  return 0;
}
